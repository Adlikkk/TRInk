{
  "name": "trade-reality-ink",
  "private": true,
  "version": "0.3.2",
  "author": "TradeReality",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "release:internal": "powershell -ExecutionPolicy Bypass -File scripts/package-internal-release.ps1",
    "release:beta": "powershell -ExecutionPolicy Bypass -File scripts/package-beta-release.ps1",
    "signing:check": "powershell -ExecutionPolicy Bypass -Command \"Write-Output 'TRInk beta builds are unsigned. Review docs/SIGNING.md for the production signing checklist.'\""
  },
  "dependencies": {
    "@tauri-apps/api": "^2.1.1",
    "@tauri-apps/plugin-dialog": "^2.2.0",
    "@tauri-apps/plugin-fs": "^2.2.0",
    "@tauri-apps/plugin-global-shortcut": "^2.2.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.1.0",
    "@types/node": "^24.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.6.3",
    "vite": "^6.0.1",
    "vitest": "^2.1.8"
  }
}
