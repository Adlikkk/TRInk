{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TradeReality Ink",
  "version": "0.1.0",
  "identifier": "com.tradereality.trink",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "TRInk",
        "width": 1600,
        "height": 900,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": true,
        "fullscreen": true,
        "visible": true,
        "shadow": false,
        "focus": true
      }
    ],
    "security": {
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "shortDescription": "Windows-first desktop overlay annotation app",
    "longDescription": "TradeReality Ink is a local-only desktop annotation overlay for educational chart markup and recording workflows.",
    "createUpdaterArtifacts": false
  }
}
