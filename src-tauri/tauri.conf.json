{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TradeReality Ink",
  "version": "0.3.2",
  "identifier": "com.tradereality.trink",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "label": "overlay",
        "title": "TRInk Overlay",
        "url": "index.html?window=overlay",
        "width": 1600,
        "height": 900,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "fullscreen": false,
        "visible": true,
        "shadow": false,
        "focus": true
      },
      {
        "label": "toolbar",
        "title": "TRInk Toolbar",
        "url": "index.html?window=toolbar",
        "width": 760,
        "height": 76,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "visible": true,
        "shadow": false,
        "focus": false
      }
    ],
    "security": {
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "shortDescription": "Windows-first desktop overlay annotation app",
    "longDescription": "TradeReality Ink is a local-only desktop annotation overlay for educational chart markup and recording workflows.",
    "publisher": "TradeReality",
    "copyright": "Copyright (c) TradeReality",
    "createUpdaterArtifacts": false
  }
}
